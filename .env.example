# Copy this file to .env.local and fill in the values.

# OpenAI API key — used server-side only for the chatbot (function/tool calling).
# Never expose this to the client.
OPENAI_API_KEY=

# Base URL for the ALDI Hackathon REST API (data source — no auth, CORS open).
ALDI_API_BASE_URL=https://hackhaton.internal.zrcn.dev
